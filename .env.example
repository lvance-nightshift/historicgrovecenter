# =============================================================================
# historicgrovecenter.com — environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values for local dev.
# For production, add the same variables in the Vercel project settings
# (Project → Settings → Environment Variables) or via `vercel env add`.
# NEVER commit .env.local — it is gitignored.
# -----------------------------------------------------------------------------

# --- Neon Postgres (data) ----------------------------------------------------
# Neon console → your project → Connection Details → connection string.
# Use the POOLED connection string (…-pooler…) for serverless.
DATABASE_URL=

# --- Neon Auth (Better Auth) -------------------------------------------------
# Neon console → Auth → Configuration → copy the Auth URL. Auth stays OFF
# until both are set. Generate the cookie secret with: openssl rand -base64 32
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# --- Cloudflare R2 (image storage) -------------------------------------------
# Cloudflare dashboard → R2. Create a bucket, then an R2 API token for it.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for served objects (no trailing slash):
# either the bucket's r2.dev URL or a custom domain like
# https://images.historicgrovecenter.com
R2_PUBLIC_URL=

# --- Email (contact form) via Zoho SMTP --------------------------------------
# Zoho Mail SMTP. SMTP_PASS must be a Zoho *app-specific password*
# (Zoho → Settings → Security → App Passwords), not your login password.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=info@historicgrovecenter.com
SMTP_PASS=
# Sender — must be the mailbox above or a verified Zoho alias:
CONTACT_FROM_EMAIL=info@historicgrovecenter.com
# Where contact-form messages are delivered:
CONTACT_TO_EMAIL=lvance@larryvance.com
